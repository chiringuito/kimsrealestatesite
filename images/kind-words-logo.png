		<style id="wp-custom-css">
			/**** header css start  ****/
.ast-above-header-wrap {
    background: #E22626;
}
.ast-sticky-active {
    background: #000;
}
#ast-fixed-header .main-header-bar {
    box-shadow: 0 0px 0px rgb(0 0 0 / 20%);
    border: 0;
}
.header-link {
    margin: 0px 0px 0px 0px !important;
    color: #fff;
}
.header-link a {
    color: #fff;
    font-size: 16px;
    margin-right: 3px;
}
.header-link .fa-phone {
    margin-right: 2px;
    position: relative;
    font-size: 18px;
    top: 2px;
    transform: rotate(0deg);
}
.header-link .fa-envelope {
    font-size: 15px;
    margin-left: 5px;
    margin-right: 2px;
    position: relative;
    top: 1px;
}
.header-link a:hover {
    color: #000;
}
.ast-above-header-wrap .astra-widget-social-profiles-inner ul {
    position: relative;
    top: 5px;
}
.ast-above-header-wrap .astra-widget-social-profiles-inner a {
    margin-bottom: 0 !important;
}
/**** header css end  ****/

.fl-row-content {
    max-width: 1240px;
}
.map-row .fl-row-content {
    max-width: 100%;
}
a {
	text-decoration: none !important;
}
.single .ast-article-single,
.single .comment-respond {
    padding: 20px 20px !important;
}
.single .post-thumb img {
    width: 100%;
}
.single .ast-primary-header-bar {
    background-color: #000;
}
.comment-textarea {
	margin-bottom: 0px !important;
}

/***** home css start ****/
.search--advanced {
    margin-top: 0 !important;
}
.search--body {
    background: #fff !important;
	box-shadow: 0px 10px 51px 3px rgb(0 0 0 / 15%);
-webkit-box-shadow: 0px 10px 51px 3px rgb(0 0 0 / 15%);
-moz-box-shadow: 0px 10px 51px 3px rgb(0 0 0 / 15%);
}
.tt-dataset-locations,
.tt-dataset-addresses,
.tt-dataset-schools {
    font-family: 'Outfit',sans-serif !important;
}
.search--body .search--select {
	    width: 49% !important;
}
.search--body input,
.search--body select {
    margin: 0 !important;
    height: 50px !important;
    padding: 0px 14px !important;
    width: 100% !important;
    background: #f2f2f2 !important;
    border: 1px #ccc solid !important;
    border-radius: 6px !important;
    color: #5a5a5a !important;
    font-size: 16px !important;
    font-family: 'Outfit',sans-serif !important;
}
.search--body button {
    background: #e22626 !important;
    border: 1px #e22626 solid !important;
    color: #ffffff !important;
    font-size: 20px !important;
    border-radius: 6px !important;
    width: 100% !important;
    padding: 9px 0px !important;
    height: inherit !important;
	    font-family: 'Outfit',sans-serif !important;
}
.search--body button:hover { 
	    background: #000 !important;
		    border: 1px #000 solid !important;
    color: #fff !important;
	transition: 0.3s;
}
.box {
    overflow: hidden;
    position: relative;
    z-index: 1;
    transition: all .5s;
    background: #fff;
    padding: 5px;
    box-shadow: 0px 10px 51px 3px rgb(0 0 0 / 15%);
    -webkit-box-shadow: 0px 10px 51px 3px rgb(0 0 0 / 15%);
    -moz-box-shadow: 0px 10px 51px 3px rgb(0 0 0 / 15%);
	    border-radius: 10px;
}
.box:hover{ box-shadow: 3px 3px 5px #999; }
.box:before,
.box:after{
    content: "";
    background: radial-gradient(circle at 23% 70%,rgba(255,255,255,0.8),#fff 30%);
    width: 150%;
    height: 150%;
    opacity: 0;
    transform: rotate(45deg);
    position: absolute;
    top:-10.5%;
    right:-150%;
    z-index: 1;
    transition: all 0.35s ease;
}
.box:after{
    background: rgba(255,255,255,0.5);
    width: 65%;
    height: 65%;
    right: auto;
    left: -20%;
    top: -65%;
}
.box:hover:before{
    opacity: 1;
    right: -85%;
}
.box:hover:after{
    opacity: 1;
    top: -42%;
}
.box img {
    width: 100%;
    height: auto;
    transition: all 0.5s ease;
    border-radius: 10px;
}
.box:hover img{ transform: scale(1.2); }
.box .box-content{
    text-align: right;
    transform: translateY(-50%);
    position: absolute;
    top: 50%;
    right: -100%;
    z-index: 2;
    transition: all .5s;
}
.box:hover .box-content{ right: 5%; }
.box .title{
    color: #000;
    font-size: 23px;
    font-weight: 700;
    text-transform: uppercase;
    margin: 0 0 3px 0;
}
.box .post{
    font-size: 16px;
    text-transform: uppercase;
    margin: 0 0 10px;
    display: block;
}
@media only screen and (max-width:990px){
.box { margin: 0 0 30px; }
}
@media only screen and (max-width:479px){
.box .title{ font-size: 20px; }
}
.nstep-name {
    text-align: center;
    line-height: 30px;
}
.nstep-name:before {
    content: '';
    display: block;
    width: 2px;
    height: 50px;
    background: #4a4242;
    margin: -15px auto 10px;
    z-index: 1;
    position: relative;
}
.nstep-name small {
    font-size: 18px;
    font-weight: 500;
    letter-spacing: 4px;
    color: #000000;
    text-transform: uppercase;
}
.nstep-name a {
    font-size: 30px;
    color: #000;
}
.nstep-name a:hover {
    color: #E22626;
}
